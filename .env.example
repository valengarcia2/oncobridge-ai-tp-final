# Copiar este archivo a ".env" y completar con valores reales.
# NUNCA commitear el archivo ".env" real al repositorio.

# --- API key del proveedor LLM (Anthropic) ---
GEMINI_API_KEY=tu-api-key-de-gemini-aca

LLM_MODEL_REASONING=gemini-2.5-flash-lite
LLM_MODEL_SUMMARIZATION=gemini-2.5-flash-lite
LLM_MODEL_VISION=gemini-2.5-flash-lite
# --- Rutas al dataset (relativas a la raíz del proyecto) ---
DATASET_ROOT=data/dataset_clinical_only/dataset

# --- Umbrales de configuración (ver config.py para el resto) ---
COMPLEX_HISTORY_THRESHOLD=5
RETRIEVER_TOP_K=5