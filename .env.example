
# --- API key del proveedor LLM 
GEMINI_API_KEY=tu-api-key-de-gemini-aca

# gemini-flash-latest: alias de Google que siempre apunta al modelo flash
# vigente -- evita romperse cuando Google deprecia una versión puntual
# (nos pasó con gemini-2.5-flash, dejó de estar disponible para API keys
# nuevas en julio 2026 sin aviso previo).
LLM_MODEL_REASONING=gemini-flash-latest
LLM_MODEL_SUMMARIZATION=gemini-flash-latest
LLM_MODEL_VISION=gemini-flash-latest
# --- Rutas al dataset 
DATASET_ROOT=data/dataset_clinical_only/dataset

# --- Umbrales de configuración
COMPLEX_HISTORY_THRESHOLD=5
RETRIEVER_TOP_K=3
# Descarta candidatos del retriever con score combinado (BM25+embeddings)
# por debajo de este valor, antes de tomar el top-k -- evita mandarle al
# LLM candidatos irrelevantes solo para completar la lista.
RETRIEVER_MIN_SCORE=0.15
# Tokens de "pensamiento" interno que el modelo gasta antes de responder
# (Gemini 2.5 = razonamiento híbrido). -1 = dinámico (el modelo decide,
# comportamiento sin este knob); 0 = lo apaga del todo. Medir tiempo/
# tokens/aciertos con distintos valores antes de la entrega final.
LLM_THINKING_BUDGET=256

# --- Componente 2: imagen de referencia (Stable Diffusion afinado en medicina) ---
STABLE_DIFFUSION_MODEL=Nihirc/Prompt2MedImage